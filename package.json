{
  "name": "@adobedjangir/commerce-admin-management",
  "version": "0.3.22",
  "description": "Schema-driven system configuration for Adobe Commerce App Builder sync apps. Magento-style scoped config in Adobe App Builder Database (ABDB) with encryption, Commerce REST helpers, and React Admin UI.",
  "license": "Apache-2.0",
  "author": "Adobe Inc.",
  "keywords": [
    "adobe-io",
    "aio",
    "app-builder",
    "adobe-commerce",
    "magento",
    "commerce-admin-management",
    "abdb",
    "react-spectrum"
  ],
  "main": "./src/index.js",
  "bin": {
    "commerce-admin-management-setup": "./scripts/setup.js"
  },
  "scripts": {
    "build": "node ./scripts/build-web.js",
    "prepublishOnly": "node ./scripts/build-web.js",
    "postinstall": "node ./scripts/setup.js && node ./scripts/discover.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./abdb": "./src/abdb-helper.js",
    "./config": "./src/abdb-config.js",
    "./crypto": "./src/system-config-crypto.js",
    "./shared": "./src/system-config-shared.js",
    "./oauth1a": "./src/oauth1a.js",
    "./web": "./web/index.js",
    "./web/index.js": "./web/index.js",
    "./web/styles.css": "./web/styles.css",
    "./web/dist/index.css": "./web/dist/index.css",
    "./web/src/styles/index.css": "./web/src/styles/index.css",
    "./actions/utils": "./actions/utils.js",
    "./actions/ext.config.yaml": "./actions/configurations/ext.config.yaml",
    "./scripts/discover": "./scripts/discover.js"
  },
  "files": [
    "src",
    "web",
    "actions",
    "scripts",
    "README.md",
    "DEVELOPER.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "dependencies": {
    "@adobedjangir/commerce-admin-get-config": "^0.0.7",
    "@adobe/aio-lib-core-auth": "^1.1.0",
    "@adobe/aio-lib-db": "^1.0.1",
    "@adobe/aio-lib-ims": "^8.0.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/djangiradobe/commerce-admin-management.git",
    "directory": "packages/commerce-admin-management"
  },
  "bugs": {
    "url": "https://github.com/djangiradobe/commerce-admin-management/issues"
  },
  "homepage": "https://github.com/djangiradobe/commerce-admin-management/tree/main/packages/commerce-admin-management#readme"
}
